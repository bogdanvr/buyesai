[Unit]
Description=BuyesAI Novofon Webhook Queue Worker
After=network.target

[Service]
Type=simple
User=bogdan
Group=bogdan
WorkingDirectory=/home/bogdan/buyesai
Environment=PROJECT_DIR=/home/bogdan/buyesai
Environment=PYTHON_BIN=/home/bogdan/buyesai/env/bin/python
Environment=NOVOFON_WEBHOOK_QUEUE_INTERVAL_SEC=5
Environment=NOVOFON_WEBHOOK_QUEUE_LIMIT=50
Environment=NOVOFON_WEBHOOK_QUEUE_MAX_RETRIES=5
Environment=NOVOFON_WEBHOOK_QUEUE_RETRY_FAILED=1
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/bogdan/buyesai/scripts/systemd/run_process_novofon_webhook_queue.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
